# Gemini REST API
DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=****
GEMINI_MODEL=gemini-3.1-flash-lite

# Groq OpenAI-compatible API
GROQ_API_KEY=****
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM OpenAI-compatible API
# NVIDIA hosted catalog example: https://integrate.api.nvidia.com/v1
# Local NIM example: http://localhost:8000/v1
NIM_API_KEY=****
NIM_BASE_URL=****
NIM_MODEL=****

ENABLE_MOCK_FALLBACK=true

SUPABASE_URL = https://****.supabase.co

SUPABASE_ANON_KEY = ****


KAKAO_REST_API_KEY=****
ENABLE_PLACE_VERIFY=true

KAKAO_MAP_API_KEY=****

GOOGLE_OAUTH_CLIENT_ID=****

GOOGLE_OAUTH_CLIENT_PW=****

KAKAO_CLIENT_ID=****

KAKAO_CLIENT_SECRET=****

GOOGLE_PLACES_API_KEY=****

KAKAO_REDIRECT_URI=****


SUPABASE_SERVICE_ROLE_KEY=****
